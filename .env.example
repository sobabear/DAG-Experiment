# Copy to .env and fill in. Never commit .env.

# Required for worker, Baseline critic, logprobs, embeddings
OPENAI_API_KEY=

# Multi-judge / context-aware ensemble (optional individually; skipped if empty)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Real GAIA (not needed for --demo)
HF_TOKEN=

# Optional overrides
# OPENAI_WORKER_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CRITIC_MODEL=gpt-4o-mini
# ANTHROPIC_CRITIC_MODEL=claude-3-5-haiku-latest
# GEMINI_CRITIC_MODEL=gemini-2.0-flash
